<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="55dp"
    android:paddingHorizontal="16dp">

    <ImageView
        android:id="@+id/sub_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_centerVertical="true"
        android:src="@drawable/walleticon"
        app:tint="@color/primary_blue" />

    <TextView
        android:id="@+id/sub_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:layout_toEndOf="@id/sub_icon"
        android:text="Sub Item"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/sub_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@id/sub_arrow"
        android:text=""
        android:textColor="@color/grey_text"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/sub_arrow"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/greatericon"
        app:tint="@color/grey_text" />

</RelativeLayout>